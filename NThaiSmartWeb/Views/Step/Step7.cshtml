@{
    ViewData["Title"] = "Step7";
    ViewBag.HideHeader = true;
    ViewBag.HideFooter = true;
}
<body class="red-background">

    <header class="page-header">
        <div class="scan_fail" style="margin-bottom:40px;">
            <img src="/images/icons/scan_fail.svg" class="scan_fail" />
        </div>
        <h1 data-i18n="unable to process">ไม่สามารถทำรายการได้</h1>
    </header>

    <div class="page-center">

        <img src="/images/icons/font_card_id.svg" class="id-card-image-fail" />

        <h2 data-i18n="your id card has expired">
            บัตรประจำตัวประชาชนของท่าน <br />
            <span class="expired-word">หมดอายุการใช้งาน</span><br>

        </h2>

    </div>

    <button class="action-button cancel-button-fail step7" data-i18n="cancel identity verification">ยกเลิกการยืนยันตัวตน</button>

    <audio id="scan_card" src="/audio/expire_card.wav"></audio>
    <audio id="click-sound" src="/audio/normal_click.wav" preload="auto"></audio>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const audio = document.getElementById("scan_card");
            if (audio) {
                audio.currentTime = 0;
                audio.play().catch(err => {
                    console.warn("ไม่สามารถเล่นเสียงอัตโนมัติได้:", err);
                });
            }
        });
    </script>
</body>