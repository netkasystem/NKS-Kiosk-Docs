@{
    ViewData["Title"] = "custom field form";
    ViewBag.HideHeader = true;
}
 <style>
    .sub-section-title {
        font-size: 2rem;
        font-weight: 600;
        color: #444;
        margin: 1rem 0 0.5rem;
        border-bottom: 1px solid #ddd;
        padding-bottom: 0.25rem;
    }

    .field-error {
        border: 2px solid red !important;
        background-color: #ffe6e6 !important;
    }
 </style>
<body class="linear-blue-background">
    <div class="kiosk-container">
        <div id="dynamic-form" class="form-scroll-area" style="padding: 24px;">
            <form id="dynamic-form-container" action="#" method="post">
 
            </form>
        </div> 
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const getCustomfieldRaw = getCustomForm();
            const getCustomfield = JSON.parse(getCustomfieldRaw);
            console.log("============ " + getCustomfield);


            function generateForm(json, containerId) {
                const container = document.getElementById(containerId);
                container.innerHTML = ''; // clear previous
  

                let currentSection = null;

                json.Schema.sort((a, b) => a.index - b.index).forEach(field => {
                    const value = json.Entries[field.id] ?? "";

                    if (field.component === "h1") {
                        currentSection = document.createElement("section");
                        currentSection.className = "form-section";

                        const sectionTitle = document.createElement("div");
                        sectionTitle.className = "section-title";

                        const h2 = document.createElement("h2");
                        h2.textContent = field.label;

                        sectionTitle.appendChild(h2);
                        currentSection.appendChild(sectionTitle);

                        container.appendChild(currentSection);
                        return;
                    }

                    const wrapper = document.createElement("div");
                    wrapper.className = "form-field";

                    switch (field.component) {
                        case "h2":
                        case "label":
                            const subTitle = document.createElement("h4");
                            subTitle.className = "sub-section-title";
                            subTitle.textContent = field.label;
                            wrapper.appendChild(subTitle);
                            break;

                        case "select":
                            const selectLabel = document.createElement("label");
                            selectLabel.textContent = field.label + (field.required ? " *" : "");
                            selectLabel.setAttribute("for", field.id);

                            const select = document.createElement("select");
                            select.id = field.id;
                            select.name = field.id;
                            if (field.required) select.required = true;

                            // เพิ่ม default option
                            const defaultOption = document.createElement("option");
                            defaultOption.value = "";
                            defaultOption.textContent = "-- โปรดเลือก --";
                            select.appendChild(defaultOption);

                            field.options.forEach((opt, i) => {
                                const option = document.createElement("option");
                                option.value = opt;
                                option.textContent = opt;
                                if (String(opt) === String(value)) {
                                    option.selected = true;
                                }
                                select.appendChild(option);
                            });

                            wrapper.appendChild(selectLabel);
                            wrapper.appendChild(select);
                            break;

                        case "textArea":
                            const textAreaLabel = document.createElement("label");
                            textAreaLabel.textContent = field.label + (field.required ? " *" : "");
                            textAreaLabel.setAttribute("for", field.id);

                            const textArea = document.createElement("textarea");
                            textArea.id = field.id;
                            textArea.name = field.id;
                            textArea.placeholder = field.placeholder || "";
                            textArea.value = value;
                            if (field.required) textArea.required = true;

                            wrapper.appendChild(textAreaLabel);
                            wrapper.appendChild(textArea);
                            break;

                        case "textInput":
                            const inputLabel = document.createElement("label");
                            inputLabel.textContent = field.label + (field.required ? " *" : "");
                            inputLabel.setAttribute("for", field.id);

                            const input = document.createElement("input");
                            input.type = "text";
                            input.id = field.id;
                            input.name = field.id;
                            input.placeholder = field.placeholder || "";
                            input.value = value;
                            if (field.required) input.required = true;

                            wrapper.appendChild(inputLabel);
                            wrapper.appendChild(input);
                            break;

                        default:
                            console.warn("ไม่รองรับ component:", field.component);
                    }

                    if (!currentSection) {
                        currentSection = document.createElement("section");
                        currentSection.className = "form-section";
                        container.appendChild(currentSection);
                    }

                    currentSection.appendChild(wrapper);
                });

                // ปุ่ม Submit
                const submitWrapper = document.createElement("div");
                submitWrapper.className = "form-field";

                const submitBtn = document.createElement("button");
                submitBtn.type = "submit";
                submitBtn.className = "submit-button";
                submitBtn.textContent = "ส่งแบบฟอร์ม | Submit Form";

                submitWrapper.appendChild(submitBtn);
                container.appendChild(submitWrapper);
            }


            generateForm(getCustomfield, "dynamic-form-container");

            // ⬇️ ดัก event การส่งฟอร์ม
            document.getElementById("dynamic-form-container").addEventListener("submit", function (event) {
                event.preventDefault(); // ป้องกันไม่ให้ reload หน้า

                const form = event.target;
                const formData = new FormData(form);
                const data = [];
                let hasError = false;

                // ตรวจสอบฟิลด์ที่ required
                getCustomfield.Schema.forEach(field => {
                    const el = document.getElementById(field.id);
                    if (el) el.classList.remove("field-error"); // ✅ ล้าง error เก่า

                    if (field.required) {
                        const value = formData.get(field.id)?.trim();

                        if (field.component === "select") {
                            if (value === "" || value === "0") {
                                hasError = true;
                                if (el) {
                                    el.classList.add("field-error");
                                    el.scrollIntoView({ behavior: "smooth", block: "center" });
                                }
                            }
                        } else {
                            if (!value) {
                                hasError = true;
                                if (el) {
                                    el.classList.add("field-error");
                                    el.scrollIntoView({ behavior: "smooth", block: "center" });
                                }
                            }
                        }
                    }
                });

                if (hasError) {
                    alert("กรุณากรอกข้อมูลให้ครบทุกช่องที่จำเป็น (required)");
                    return;
                }

                // ดึงค่าทั้งหมดไปใส่ object
                for (let [key, value] of formData.entries()) {
                    var customField = {
                        customFieldId : key,
                        customFieldValue : value
                    }
                    data.push(customField);
                }
                setCustomData(data); 
                window.Step14.save_consent();
            });
        });


    </script>
</body>

