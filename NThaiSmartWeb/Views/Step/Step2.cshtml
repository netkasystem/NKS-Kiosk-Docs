    <body class="kiosk-body">
        <div class="bg-decoration z-0">
            <div class="bg-gradient-top-notice"></div>
            <div class="bg-gradient-bottom"></div>
        </div>
        <div class="kiosk-content z-10">
            <header class="kiosk-header">
                <div class="logo-container">
                    <img id="photo" src="/images/icons/maersk.png" alt="Maersk Logo" class="maersk-img" />
                </div>

            </header>

            <div class="welcome-text-section">
                <h1 class="title-th" data-i18n="identity verification steps">ขั้นตอนการยืนยันตัวตน</h1>
                <div class="divider"></div>
            </div>

            <div class="kiosk-vertical-container">
                <div class="kiosk-step-card">
                    <div class="step-visual-box">
                        <div class="step-main-number">1</div>
                    </div>
                    <div class="content-holder">
                        <h2 class="step-instruction-text" data-i18n="insert id card into reader">สอดบัตรประจำตัวประชาชนเข้าช่องอ่าน</h2>
                    </div>
                </div>

                <div class="kiosk-step-card">
                    <div class="step-visual-box">
                        <div class="step-main-number">2</div>
                    </div>
                    <div class="content-holder">
                        <h2 class="step-instruction-text" data-i18n="scan face to verify identity">สแกนใบหน้าเพื่อยืนยันตัวตน</h2>
                        <div class="step-info-tag" data-i18n="skip to step 3 if already verified">หากเคยยืนยันตัวตนแล้ว ระบบจะข้ามไปขั้นตอนที่ 3</div>
                    </div>
                </div>

                <div class="kiosk-step-card">
                    <div class="step-visual-box">
                        <div class="step-main-number">3</div>
                    </div>
                    <div class="content-holder">
                        <h2 class="step-instruction-text" data-i18n="review id card data and confirm consent">ตรวจสอบข้อมูลจากบัตรประจำตัวประชาชนและเลือกยืนยันการให้ความยินยอม</h2>
                    </div>
                </div>

                <div class="kiosk-step-card">
                    <div class="step-visual-box">
                        <div class="step-main-number">4</div>
                    </div>
                    <div class="content-holder">
                        <h2 class="step-instruction-text" data-i18n="retrieve id card from reader">รับบัตรประจำตัวประชาชนคืนจากช่องอ่าน</h2>
                    </div>
                </div>
            </div>

            <div class="kiosk-action-bar style-modern">
                <a asp-controller="Step" asp-action="Step3" class="kiosk-btn btn-solid" data-i18n="ready">
                    พร้อมแล้ว
                </a>
            </div>
        </div>
    </body>

</a>
