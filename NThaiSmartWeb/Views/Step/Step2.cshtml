@{
    ViewData["Title"] = "Step2";
    ViewBag.HideHeader = true;
    ViewBag.HideFooter = true;
}

<body class="kiosk-body">

    <div class="bg-decoration z-0">
        <div class="bg-gradient-top-notice"></div>
        <div class="bg-gradient-bottom"></div>
    </div>

    <div class="kiosk-content z-10">

        <header class="kiosk-header">
            <div class="logo-container">
                <img id="photo" src="/images/icons/maersk.png" alt="Maersk Logo" class="maersk-img" />
            </div>

            <div class="lang-toggle-group">
                <button class="lang-btn active" onclick="setLang('th')">TH</button>
                <div class="lang-separator"></div>
                <button class="lang-btn" onclick="setLang('en')">EN</button>
            </div>
        </header>

        <div class="welcome-text-section">
            <h1 class="title-th">แจ้งเตือนสิทธิ</h1>
            <div class="divider"></div>
        </div>
        <div class="privacy-container-single">
            <div class="privacy-notice-box">
                <div class="notice-body">
                 
                    <div class="details-section">
                        <p class="transmission-text">
                            ตู้นี้มีการเก็บข้อมูลส่วนบุคคลและภาพถ่ายเพื่อใช้ในการลงทะเบียนและยืนยันตัวตนของผู้เข้าพื้นที่
                        </p>
                        <h4 class="section-title">ข้อมูลที่จัดเก็บ:</h4>
                        <p class="detail-item">• ข้อมูลส่วนบุคคลจาก<strong> บัตรประชาชน</strong> (ชื่อ-นามสกุล, เลขประจำตัวประชาชน)</p>
                        <p class="detail-item">• <strong>ภาพถ่ายใบหน้า </strong>จากกล้องประมวลผล ณ จุดลงทะเบียน</p>
                        <p class="transmission-text">
                            ข้อมูลทั้งหมดจะถูกส่งไปยังระบบ <strong>Netka Intelligent</strong> เพื่อดำเนินการประมวลผล ตรวจสอบ และยืนยันตัวตนตามวัตถุประสงค์ด้านความปลอดภัยที่ได้แจ้งไว้ข้างต้นอย่างเคร่งครัด
                        </p>
                    </div>
                    <div class="scroll-spacer"></div>
                </div>

                <div class="bubble bubble-single"></div>
            </div>
        </div>

        <div class="spacer"></div>

        <div class="kiosk-action-bar style-modern">
            <a asp-controller="Step" asp-action="Step4" class="kiosk-btn btn-solid">
                ยอมรับและดำเนินการต่อ
            </a>

            <button class="kiosk-btn btn-outline" onclick="history.back()">
             ยกเลิก
            </button>
            
        </div>
      
    </div>
</body>
