@{
    ViewData["Title"] = "Step9";
    ViewBag.HideHeader = true;
    ViewBag.HideFooter = true;
}
<a asp-controller="Step" asp-action="Step10" class="card-link" style="text-decoration: none;">
    <section class="main">
        <div class="header" style="margin-top:0px;">
            <header class="page-header" style="margin-bottom:0px;">
                <div class="step-number" style="margin-bottom:60px;">2</div>
                <h1 data-i18n="face scan">สแกนใบหน้า</h1>
            </header>
            <h3 style="color:#fff; text-align:center;" data-i18n="how to scan your face">วิธีการสแกนใบหน้า</h3>
            <div class="step-container" style="margin-top:20%;">

                <div class="step" style="text-align:left;">
                    <div class="face_scan">
                        <img src="/images/icons/face-scan.svg" class="face_scan" />
                    </div>
                    <div class="step-text" style="margin-left:60px;" data-i18n="please stand straight and look at the camera">กรุณายืนตัวตรง และมองไปที่กล้อง</div>
                </div>
                <div class="step" style="text-align:left;">
                    <div class="face_scan">
                        <img src="/images/icons/face_scan2.svg" class="face_scan" />
                    </div>
                    <div class="step-text" style="margin-left:60px;" data-i18n="please remove mask or face covering">
                        หากสวมใส่หน้ากากอนามัยหรือสิ่งที่บดบังใบหน้า กรุณาถอดออก
                    </div>
                </div>
                <div class="step" style="text-align:left;">
                    <div class="face_scan">
                        <img src="/images/icons/Face_scan3.svg" class="face_scan" />
                    </div>
                    <div class="step-text" style="margin-left:60px;" data-i18n="wait until face scan is complete">
                        รอจนกว่าจะขึ้นการแสกนใบหน้าเสร็จสิ้นจึงจะสามารถสิ้นสุดการสแกนใบหน้า
                    </div>
                </div>
                <div class="click-hint" style="margin:10%;">
                    <img id="interac" src="/images/icons/Interac.svg" class="interac_icon" />
                    <div class="ping-center"></div>
                </div>
            </div>
        </div>
        <audio id="click-sound" src="/audio/normal_click.wav" preload="auto"></audio>

    </section>
</a>