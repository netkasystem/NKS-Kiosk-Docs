@{
    ViewData["Title"] = "Integrate NDPP";
    ViewBag.HideHeader = true;
    ViewBag.HideFooter = true;
}

<body class="bg-light">
    <div class="container py-4">

        <!-- Card List -->
        <div id="ndpp-container" class="row g-3"></div>

        <!-- Iframe Container -->
        <div id="iframe-container" class="mt-3" style="display:none; height:600px;">
            <div class="d-flex justify-content-between mb-2">
                <button id="btn-back" class="btn btn-secondary">← ย้อนกลับ</button>
            </div>
            <iframe id="preview-frame" style="width:100%; height:100%; border:1px solid #ccc;"></iframe>
        </div>

    </div>

    <script>
        document.addEventListener("DOMContentLoaded", async function () {
            const container = document.getElementById("ndpp-container");
            const iframeContainer = document.getElementById("iframe-container");
            const iframe = document.getElementById("preview-frame");
            const btnBack = document.getElementById("btn-back");

            // ดึงข้อมูล NDPP
            const getIntegrateNdppData = await getIntegrateNdpp();
            container.innerHTML = "";

            getIntegrateNdppData.forEach(item => {
                const col = document.createElement("div");
                col.className = "col-12 col-sm-6 col-lg-4";

                col.innerHTML = `
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">${item.serviceName}</h5>
                            <p class="card-text text-truncate" style="max-height:3.6em;">${item.serviceDescription}</p>
                            <p class="mb-1"><small>เริ่ม: ${new Date(item.serviceStartDate).toLocaleString()}</small></p>
                            <p class="mb-2"><small>สิ้นสุด: ${new Date(item.serviceStopDate).toLocaleString()}</small></p>
                            <button class="btn btn-primary mt-auto btn-open" data-url="${item.ndppPreferenceUrl}">เปิดดู</button>
                        </div>
                    </div>
                `;
                container.appendChild(col);
            });

            // เปิด iframe
            container.addEventListener("click", function(e) {
                if (e.target.classList.contains("btn-open")) {
                    const url = e.target.getAttribute("data-url");
                    iframe.src = url;
                    container.style.display = "none";
                    iframeContainer.style.display = "block";
                }
            });

            // ปุ่มย้อนกลับ
            btnBack.addEventListener("click", function() {
                iframe.src = "";
                iframeContainer.style.display = "none";
                container.style.display = "flex";
            });
        });
    </script>
</body>
