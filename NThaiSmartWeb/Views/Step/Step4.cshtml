@{
    ViewData["Title"] = "Step4";
    ViewBag.HideHeader = true;
    ViewBag.HideFooter = true;
}

<header class="page-header">
    <div class="step-number" style="margin-bottom:60px;">1</div>
    <h1 style="font-size:76px;" data-i18n="please insert your national id card">กรุณาสอดบัตรประจำตัวชาชน</h1>
</header>
<div class="mainCard-container">
    <div class="left-column">

        <div class="reader-slot">
            <img src="/images/icons/Readercard.svg" class="Readercard" />
            <img src="/images/icons/outside_reder.svg" class="outside-reader" />

        </div>
        <div class="hand-with-card">
            <img src="/images/icons/hand_card.svg" class="Heandcard" />
        </div>

    </div>
    <div class="right-column">
        <div class="top-section">
            <img src="/images/icons/font_card_id.svg" class="id-card-image" />
        </div>

        <div class="bottom-section">
            <ol class="instruction-list">
                <li data-i18n="prepare your national id card">เตรียมบัตรประจำตัวประชาชน</li>
                <li data-i18n="face the card up as shown and insert into reader">โปรดหงายบัตรตามภาพ และสอดบัตรเข้าช่องอ่านบัตร</li>
                <li data-i18n="do not remove the card until the process is complete">กรุณาอย่าดึงบัตรออก จนกว่าการทำรายการจะเสร็จสมบูรณ์</li>
                <li class="Alert d-none" id="alert-notfound-card" data-i18n="id card not detected">ระบบยังไม่พบบัตรประจำตัวประชาชน</li>

            </ol>
        </div>
    </div>

</div>
<audio id="scan_card" src="/audio/Step_scan_card.wav"></audio>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const audio = document.getElementById("scan_card");
        if (audio) {
            audio.currentTime = 0;
            audio.play().catch(err => {
                console.warn("ไม่สามารถเล่นเสียงอัตโนมัติได้:", err);
            });
        }
    });
</script>