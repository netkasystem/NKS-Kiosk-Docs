@{
    ViewData["Title"] = "Step12";
    ViewBag.HideHeader = true;
    ViewBag.HideFooter = true;
}
<body>
    <header class="page-header" style="margin-bottom: 0px;">
        <h1>กรุณายืนยันข้อมูล</h1>
    </header>

    <div class="row">
        <div class="grid-item top-box">
            <div class="info-header d-flex justify-content-between align-items-center">
                <h2>ข้อมูลบัตรประชาชน</h2>
                <div class="action-buttons">
                    <button class="icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-6 info-field">
                    <label>เลขบัตรประชาชน</label>
                    <div class="info-value" data-field-name="citizenID" data-full-value=""></div>
                    <button class="local-icon-button w-100">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-12 col-md-6 info-field">
                    <label>วันเกิด</label>
                    <div class="info-value" data-field-name="dateOfBirth" data-full-value=""></div>
                    <button class="local-icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-12 col-md-6 info-field">
                    <label>ชื่อ</label>
                    <div class="info-value" data-field-name="firstNameTH" data-full-value=""></div>
                    <button class="local-icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-12 col-md-6 info-field">
                    <label>นามสกุล</label>
                    <div class="info-value" data-field-name="lastNameTH" data-full-value=""></div>
                    <button class="local-icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-12 col-md-6 info-field">
                    <label>ชื่อ (ภาษาอังกฤษ)</label>
                    <div class="info-value" data-field-name="firstNameEN" data-full-value=""></div>
                    <button class="local-icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-12 col-md-6 info-field">
                    <label>นามสกุล (ภาษาอังกฤษ)</label>
                    <div class="info-value" data-field-name="lastNameEN" data-full-value=""></div>
                    <button class="local-icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-12 info-field">
                    <label>เพศ</label>
                    <div class="info-value" data-field-name="sex" data-full-value=""></div>
                    <button class="local-icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-12 info-field">
                    <label>ที่อยู่</label>
                    <div class="info-value" data-field-name="address" data-full-value=""></div>
                    <button class="local-icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-12 col-md-6 info-field">
                    <label>วันออกบัตร</label>
                    <div class="info-value" data-field-name="issueDate" data-full-value=""></div>
                    <button class="local-icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-12 col-md-6 info-field">
                    <label>วันหมดอายุบัตร</label>
                    <div class="info-value" data-field-name="expireDate" data-full-value=""></div>
                    <button class="local-icon-button">
                        <img src="/images/icons/vision.svg" alt="ดูข้อมูล" />
                    </button>
                </div>

                <div class="col-6">
                    <div class="grid-item bottom-left-1">
                        <div class="crop-box">
                            <img id="idCardPhoto" src="/images/icons/Profile_id.svg" alt="รูปโปรไฟล์จากบัตรประชาชน" />
                        </div>
                        <h3>รูปบัตรประชาชน</h3>
                    </div>
                </div>

                <div class="col-6">
                    <div class="grid-item bottom-left-2">
                        <div class="crop-box">
                            <img id="capturePhoto" src="/images/icons/Profile.jpg" alt="รูปโปรไฟล์ที่ถ่าย" class="crop-box" />
                        </div>
                        <h3>รูปจากการแสกนใบหน้า</h3>
                    </div>
                </div>

                <div class="col-6">
                    <button type="submit" class="edit-button w-100 py-4">แก้ไขข้อมูล</button>
                </div>

                <div class="col-6">
                    <button type="button" class="confirm-button w-100 py-4" id="confirm-btn">ยืนยันข้อมูล</button>
                </div>

            </div>
        </div>
    </div>

    <div id="edit-modal" class="modal-overlay">
        <div class="modal-content">

            <div class="modal-header">
                <h2 style="margin:0px;">แก้ไขข้อมูล</h2>
                <span class="close-button">&times;</span>
            </div>

            <form id="edit-form">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="input-id-number">เลขบัตรประชาชน</label>
                        <div class="input-wrapper">
                            <span class="old-data-placeholder"></span> <input type="text" id="input-id-number" data-source-field="citizenID">
                        </div>
                    </div>
                    <div class="form-field">
                        <label for="input-dateOfBirth">วันเกิด</label>
                        <input type="text" id="input-dateOfBirth" data-source-field="dateOfBirth">
                    </div>

                    <div class="form-field">
                        <label for="input-first-name">ชื่อ</label>
                        <input type="text" id="input-first-name" data-source-field="firstNameTH">
                    </div>

                    <div class="form-field">
                        <label for="input-last-name">นามสกุล</label>
                        <input type="text" id="input-last-name" data-source-field="lastNameTH">
                    </div>

                    <div class="form-field">
                        <label for="input-first-name">ชื่อ (ภาษาอังกฤษ)</label>
                        <input type="text" id="input-first-name" data-source-field="firstNameEN">
                    </div>

                    <div class="form-field">
                        <label for="input-last-name">นามสกุล (ภาษาอังกฤษ)</label>
                        <input type="text" id="input-last-name" data-source-field="lastNameEN">
                    </div>

                    <div class="form-field  full-width">
                        <label for="input-sex">เพศ</label>
                        <input type="text" id="input-sex" data-source-field="sex">
                    </div>

                    @*   <div class="form-field">
                        <label for="input-religion">ศาสนา</label>
                        <input type="text" id="input-religion" data-source-field="religion">
                    </div> *@

                    <div class="form-field full-width">
                        <label for="input-address">ที่อยู่</label>
                        <textarea id="input-address" rows="3" data-source-field="address"></textarea>
                    </div>

                    <div class="form-field">
                        <label for="input-issue-date">วันออกบัตร</label>
                        <input type="text" id="input-issue-date" data-source-field="issueDate">
                    </div>

                    <div class="form-field">
                        <label for="input-expiry-date">วันหมดอายุบัตร</label>
                        <input type="text" id="input-expiry-date" data-source-field="expireDate">
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="cancel-button">ยกเลิก</button>

                    <button type="submit" class="save-button">บันทึกข้อมูล</button>

                </div>
            </form>
            <div id="confirmation-modal" class="confirmation-modal-overlay">
                <div class="modal-confirmation">
                    <img src="/images/icons/confirmation.svg" class="congratulations-image" style="margin-bottom:40px; margin-top:40px;" />
                    <p>คุณแน่ใจหรือไม่ว่าต้องการบันทึกข้อมูลนี้?</p>
                    <div class="modal-footer">
                        <button id="cancel-confirm-button" class="cancel-button">ยกเลิก</button>
                        <button id="confirm-save-button" class="save-button">ยืนยัน</button>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let cardData = getCardData();

            // ---  ควบคุมปุ่มแสดงผลทั้งหมด (ใน Header) ---
            const mainToggleButton = document.querySelector(".info-header .icon-button");
            const allInfoValues = document.querySelectorAll(".info-value");

            if (mainToggleButton) {
                const mainEyeIcon = mainToggleButton.querySelector("img");
                let isAllDataVisible = false;

                mainToggleButton.addEventListener("click", function () {
                    isAllDataVisible = !isAllDataVisible;

                    allInfoValues.forEach((element) => {
                        const fullValue = element.dataset.fullValue;
                        const maskedValueKey = "data-masked-value";

                        if (isAllDataVisible) {
                            if (!element.hasAttribute(maskedValueKey)) {
                                element.setAttribute(maskedValueKey, element.textContent);
                            }
                            element.textContent = fullValue;
                        } else {
                            if (element.hasAttribute(maskedValueKey)) {
                                element.textContent = element.getAttribute(maskedValueKey);
                            }
                        }
                    });

                    // อัปเดตไอคอนของปุ่มทั้งหมดและปุ่มแยกให้อยู่ในสถานะเดียวกัน
                    updateAllIcons(isAllDataVisible);
                });
            }

            // ---  ควบคุมปุ่มแสดงผลแยกแต่ละช่อง ---
            const localToggleButtons = document.querySelectorAll(".local-icon-button");

            localToggleButtons.forEach((button) => {
                const infoField = button.closest(".info-field");
                let isDataVisible = false; // สถานะของแต่ละปุ่ม

                button.addEventListener("click", function () {
                  isDataVisible = !isDataVisible;

                  const infoValueElement = this.parentElement.querySelector(".info-value");
                  const eyeIcon = button.querySelector("img");
                  const fullValue = infoValueElement.dataset.fullValue;
                  const maskedValue = infoValueElement.dataset.maskValue;

                  if (isDataVisible) {
                    infoValueElement.textContent = fullValue;
                    eyeIcon.src = "/images/icons/eye.svg";
                    eyeIcon.alt = "ซ่อนข้อมูล";
                  } else {
                    infoValueElement.textContent = maskedValue;
                    eyeIcon.src = "/images/icons/vision.svg";
                    eyeIcon.alt = "ดูข้อมูล";
                  }
                });
            });

            // --- ฟังก์ชันเสริม: อัปเดตไอคอนทั้งหมด ---
            function updateAllIcons(isVisible) {
                const allIcons = document.querySelectorAll(".icon-button img, .local-icon-button img");
                allIcons.forEach((icon) => {
                    if (isVisible) {
                        icon.src = "/images/icons/eye.svg";
                        icon.alt = "ซ่อนข้อมูล";
                    } else {
                        icon.src = "/images/icons/vision.svg";
                        icon.alt = "ดูข้อมูล";
                    }
                });
            }

            // --- 3. ควบคุมการทำงานของ Modal แก้ไขข้อมูล  ---
            const editButton = document.querySelector(".edit-button");
            const editModal = document.getElementById("edit-modal");
            const confirmModal = document.getElementById("confirmation-modal");

            if (editModal && confirmModal) {
                const closeEditModalButton = editModal.querySelector(".close-button");
                const cancelEditButton = editModal.querySelector(".cancel-button");
                const editForm = document.getElementById("edit-form");
                const infoValuesOnPage = document.querySelectorAll(".info-value");
                const confirmSaveBtn = document.getElementById("confirm-save-button");
                const cancelConfirmBtn = document.getElementById("cancel-confirm-button");

                function openEditModal() {
                  infoValuesOnPage.forEach((infoDiv) => {
                    const fieldName = infoDiv.dataset.fieldName;
                    const fullValue = infoDiv.dataset.fullValue;
                    const inputTarget = editModal.querySelector(`[data-source-field="${fieldName}"]`);
                    if (inputTarget) {
                      const wrapper = inputTarget.closest(".input-wrapper");
                      if (wrapper) {
                        const placeholderTarget = wrapper.querySelector(".old-data-placeholder");
                        if (placeholderTarget) {
                          placeholderTarget.textContent = fullValue;
                        }
                      }
                      inputTarget.value = fullValue;
                    }
                  });
                  editModal.style.display = "flex";
                }

                function closeEditModal() {
                  editModal.style.display = "none";
                }

                function closeConfirmModal() {
                  confirmModal.style.display = "none";
                }

                function saveChanges() {
                  const updatedData = {};
                  editForm.querySelectorAll("[data-source-field]").forEach((input) => {
                    const fieldName = input.dataset.sourceField;
                    updatedData[fieldName] = input.value;
                  });

                  console.log("ข้อมูลที่จะส่งไปบันทึก:", updatedData);
                  cardData.updatedData = updatedData;

                  // ✅ Save กลับ sessionStorage
                  setCardData(cardData);

                  infoValuesOnPage.forEach((infoDiv) => {
                    const fieldName = infoDiv.dataset.fieldName;
                    if (updatedData[fieldName]) {
                      infoDiv.dataset.fullValue = updatedData[fieldName];
                    }
                  });
                  populateCardData(cardData);
                  closeEditModal();
                  closeConfirmModal();
                }

                editForm.addEventListener("submit", function (event) {
                  event.preventDefault();
                  confirmModal.style.display = "flex";
                });

                if (editButton) editButton.addEventListener("click", openEditModal);
                if (closeEditModalButton) closeEditModalButton.addEventListener("click", closeEditModal);
                if (cancelEditButton) cancelEditButton.addEventListener("click", closeEditModal);
                if (cancelConfirmBtn) cancelConfirmBtn.addEventListener("click", closeConfirmModal);
                if (confirmSaveBtn) confirmSaveBtn.addEventListener("click", saveChanges);
            }

            // ฟังก์ชันช่วย
            function formatDateTH(dateStr) {
                const monthTH = ["", "ม.ค.", "ก.พ.", "มี.ค.", "เม.ย.", "พ.ค.", "มิ.ย.", "ก.ค.", "ส.ค.", "ก.ย.", "ต.ค.", "พ.ย.", "ธ.ค."];
                const d = new Date(dateStr);
                const day = d.getDate();
                const month = monthTH[d.getMonth() + 1];
                const year = d.getFullYear() + 543;
                return `${day} ${month} ${year}`;
            }

            function maskText(text, visible = 3) {
                if (!text || text.length <= visible) return "*".repeat(text.length);
                const hidden = "x".repeat(text.length - visible);
                return hidden + text.slice(-visible);
            }

            function getsexText(code) {
                return code === "1" ? "ชาย" : code === "2" ? "หญิง" : "xxx";
            }

            function getAddress(addr) {
                return `${addr.houseNo} ${addr.road} ${addr.subDistrict} ${addr.district} ${addr.province} ${addr.postalCode ?? ""}`;
            }

              // 🎯 ใส่ข้อมูลทั้งหมดลง DOM
            function populateCardData(data) {
                const fields = data.updatedData;

                if (data.photo?.startsWith("data:image")) {
                  const photoImg = document.getElementById("idCardPhoto");
                  if (photoImg) {
                    photoImg.src = data.photo;
                  }
                }

                const ignoreMask = ["sex"];
                Object.entries(fields).forEach(([key, value]) => {
                  const el = document.querySelector(`.info-value[data-field-name="${key}"]`);
                  if (el) {
                    var maskVal = maskText(value);

                    if(ignoreMask.includes(key))maskVal = value;

                    el.setAttribute("data-full-value", value);
                    el.setAttribute("data-mask-value", maskVal);
                    el.textContent = maskVal;
                  }
                });
            }

            var capture = getCapture();
            if (capture) {
                const captureImg = document.getElementById("capturePhoto");
                if (captureImg) {
                  captureImg.src = capture;
                }
            }

            if (cardData) {
                 const fields = {
                  citizenID: cardData.citizenID,
                  dateOfBirth: formatDateTH(cardData.dateOfBirth),
                  firstNameTH: cardData.thaiPersonalInfo.firstName,
                  lastNameTH: cardData.thaiPersonalInfo.lastName,
                  firstNameEN: cardData.englishPersonalInfo.firstName,
                  lastNameEN: cardData.englishPersonalInfo.lastName,
                  sex: getsexText(cardData.sex),
                  religion: "xxx", // ยังไม่มีใน object
                  address: getAddress(cardData.addressInfo),
                  issueDate: formatDateTH(cardData.issueDate),
                  expireDate: formatDateTH(cardData.expireDate),
                };
                cardData.updatedData = fields;
                populateCardData(cardData);
            }
            const ConfirmBtn = document.getElementById("confirm-btn");
            if (ConfirmBtn) ConfirmBtn.addEventListener("click", ConfirmData);

            function ConfirmData() {
                const getCustomfieldRaw = getCustomForm();
                if(getCustomfieldRaw == "") window.Step14.save_consent();
                else{
                    const getCustomfield = JSON.parse(getCustomfieldRaw);
                    if (getCustomfield != null) window.location.href = "/Step/Step14";
                    else {
                        window.Step14.save_consent();
                    }
                }

            }
        });
    </script>

    <audio id="click-sound" src="/audio/normal_click.wav" preload="auto"></audio>

</body>
