                        <input type="text" id="input-issue-date" data-source-field="issue_date">
                    </div>

                    <div class="form-field">
                        <label for="input-expiry-date">วันหมดอายุบัตร</label>
                        <input type="text" id="input-expiry-date" data-source-field="expiry_date">
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="cancel-button">ยกเลิก</button>
                    <button type="submit" class="save-button">บันทึกข้อมูล</button>
                </div>
            </form>
            <div id="confirmation-modal" class="modal-overlay">
    <div class="modal-confirm">
        <p>คุณแน่ใจหรือไม่ว่าต้องการบันทึกข้อมูลนี้?</p>
        <div class="modal-footer">
            <button id="cancel-confirm-button" class="cancel-button">ยกเลิก</button>
            <button id="confirm-save-button" class="save-button">ยืนยัน</button>
        </div>
    </div>
</div>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function() {

            // ---  ควบคุมปุ่มแสดงผลทั้งหมด (ใน Header) ---
            const mainToggleButton = document.querySelector('.info-header .icon-button');
            const allInfoValues = document.querySelectorAll('.info-value');

            if (mainToggleButton) {
                const mainEyeIcon = mainToggleButton.querySelector('img');
                let isAllDataVisible = false;

                mainToggleButton.addEventListener('click', function() {
                    isAllDataVisible = !isAllDataVisible;

                    allInfoValues.forEach(element => {
                        const fullValue = element.dataset.fullValue;
                        const maskedValueKey = 'data-masked-value';

                        if (isAllDataVisible) {
                            if (!element.hasAttribute(maskedValueKey)) {
                                element.setAttribute(maskedValueKey, element.textContent);
                            }
                            element.textContent = fullValue;
                        } else {
                            if (element.hasAttribute(maskedValueKey)) {
                                element.textContent = element.getAttribute(maskedValueKey);
                            }
                        }
                    });

                    // อัปเดตไอคอนของปุ่มทั้งหมดและปุ่มแยกให้อยู่ในสถานะเดียวกัน
                    updateAllIcons(isAllDataVisible);
                });
            }

            // ---  ควบคุมปุ่มแสดงผลแยกแต่ละช่อง ---
            const localToggleButtons = document.querySelectorAll('.local-icon-button');

            localToggleButtons.forEach(button => {
                const infoField = button.closest('.info-field');
                const infoValueElement = infoField.querySelector('.info-value');
                const maskedValue = infoValueElement.textContent;
                let isDataVisible = false; // สถานะของแต่ละปุ่ม

                button.addEventListener('click', function() {
                    isDataVisible = !isDataVisible;

                    const eyeIcon = button.querySelector('img');
                    const fullValue = infoValueElement.dataset.fullValue;

                    if (isDataVisible) {
                        infoValueElement.textContent = fullValue;
                        eyeIcon.src = '/images/icons/eye.svg';
                        eyeIcon.alt = 'ซ่อนข้อมูล';
                    } else {
                        infoValueElement.textContent = maskedValue;
                        eyeIcon.src = '/images/icons/vision.svg';
                        eyeIcon.alt = 'ดูข้อมูล';
                    }
                });
            });

            // --- ฟังก์ชันเสริม: อัปเดตไอคอนทั้งหมด ---
            function updateAllIcons(isVisible) {
                const allIcons = document.querySelectorAll('.icon-button img, .local-icon-button img');
                allIcons.forEach(icon => {
                    if (isVisible) {
                        icon.src = '/images/icons/eye.svg';
                        icon.alt = 'ซ่อนข้อมูล';
                    } else {
                        icon.src = '/images/icons/vision.svg';
                        icon.alt = 'ดูข้อมูล';
                    }
                });
            }


            // --- 3. ควบคุมการทำงานของ Modal แก้ไขข้อมูล  ---
            const editButton = document.querySelector('.edit-button');
            const editModal = document.getElementById('edit-modal');
            const confirmModal = document.getElementById('confirmation-modal');

            if (editModal && confirmModal) {
                const closeEditModalButton = editModal.querySelector('.close-button');
                const cancelEditButton = editModal.querySelector('.cancel-button');
                const editForm = document.getElementById('edit-form');
                const infoValuesOnPage = document.querySelectorAll('.info-value');
                const confirmSaveBtn = document.getElementById('confirm-save-button');
                const cancelConfirmBtn = document.getElementById('cancel-confirm-button');

                function openEditModal() {
                    infoValuesOnPage.forEach(infoDiv => {
                        const fieldName = infoDiv.dataset.fieldName;
                        const fullValue = infoDiv.dataset.fullValue;
                        const inputTarget = editModal.querySelector(`[data-source-field="${fieldName}"]`);
                        if (inputTarget) {
                            const wrapper = inputTarget.closest('.input-wrapper');
                            if (wrapper) {
                                const placeholderTarget = wrapper.querySelector('.old-data-placeholder');
                                if (placeholderTarget) {
                                    placeholderTarget.textContent = fullValue;
                                }
                            }
                            inputTarget.value = fullValue;
                        }
                    });
                    editModal.style.display = 'flex';
                }

                function closeEditModal() {
                    editModal.style.display = 'none';
                }

                function closeConfirmModal() {
                    confirmModal.style.display = 'none';
                }

                function saveChanges() {
                    const updatedData = {};
                    editForm.querySelectorAll('[data-source-field]').forEach(input => {
                        const fieldName = input.dataset.sourceField;
                        updatedData[fieldName] = input.value;
                    });
                    console.log('ข้อมูลที่จะส่งไปบันทึก:', updatedData);
                    alert('บันทึกข้อมูลเรียบร้อย! (จำลอง)');
                    infoValuesOnPage.forEach(infoDiv => {
                        const fieldName = infoDiv.dataset.fieldName;
                        if (updatedData[fieldName]) {
                            infoDiv.dataset.fullValue = updatedData[fieldName];
                        }
                    });
                    closeEditModal();
                    closeConfirmModal();
                }

                editForm.addEventListener('submit', function(event) {
                    event.preventDefault();
                    confirmModal.style.display = 'flex';
                });

                if (editButton) editButton.addEventListener('click', openEditModal);
                if (closeEditModalButton) closeEditModalButton.addEventListener('click', closeEditModal);
                if (cancelEditButton) cancelEditButton.addEventListener('click', closeEditModal);
                if (cancelConfirmBtn) cancelConfirmBtn.addEventListener('click', closeConfirmModal);
                if (confirmSaveBtn) confirmSaveBtn.addEventListener('click', saveChanges);
            }
        });
    </script>
</body>
