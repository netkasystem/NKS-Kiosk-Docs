    <script>
              document.addEventListener("DOMContentLoaded", function () {
            let cardData = getCardData();
            const mainToggleButton = document.getElementById("toggle-vision-btn");
            const allInfoValues = document.querySelectorAll(".info-value");
            const toggleBtn = document.getElementById('data-list-toggle');
            const content = document.getElementById('collapsible-list');

            if (toggleBtn && content) {
                toggleBtn.addEventListener('click', function() {
                    content.classList.toggle('is-expanded');
                    toggleBtn.classList.toggle('is-active');

                    const label = toggleBtn.querySelector('span');
                    if (content.classList.contains('is-expanded')) {
                    } else {
                    }
                });
            }

            if (mainToggleButton) {
                let isAllDataVisible = false;

                mainToggleButton.addEventListener("click", function () {
                    isAllDataVisible = !isAllDataVisible;

                    allInfoValues.forEach((element) => {
                        const fullValue = element.getAttribute("data-full-value");
                        const maskedValue = element.getAttribute("data-mask-value");

                        if (isAllDataVisible) {
                            element.textContent = fullValue || element.textContent;
                        } else {
                            element.textContent = maskedValue || element.textContent;
                        }
                    });

                    updateAllIcons(isAllDataVisible);
                });
            }

            function updateAllIcons(isVisible) {
                const mainIcon = document.querySelector("#toggle-vision-btn img");
                if (mainIcon) {
                    if (isVisible) {
                        mainIcon.src = "/images/icons/eye.svg"; 
                        mainIcon.alt = "ซ่อนข้อมูล";
                    } else {
                        mainIcon.src = "/images/icons/vision.svg"; 
                        mainIcon.alt = "ดูข้อมูล";
                    }
                }
            }

            function formatDateTH(dateStr) {
                if (!dateStr) return "";
                const monthTH = ["", "ม.ค.", "ก.พ.", "มี.ค.", "เม.ย.", "พ.ค.", "มิ.ย.", "ก.ค.", "ส.ค.", "ก.ย.", "ต.ค.", "พ.ย.", "ธ.ค."];
                const d = new Date(dateStr);
                return `${d.getDate()} ${monthTH[d.getMonth() + 1]} ${d.getFullYear() + 543}`;
            }

            function hideLastN(text, count = 4) {
                if (!text) return "";
                const str = String(text);
                if (str.length <= count) return "x".repeat(str.length);
                return str.slice(0, -count) + "x".repeat(count);
            }

            const maskText = (text) => hideLastN(text, 4);

            function getsexText(code) {
                return code === "1" ? "ชาย" : code === "2" ? "หญิง" : "ไม่ระบุ";
            }

            function getAddress(addr) {
                if (!addr) return "";
                return `${addr.houseNo || ''} ${addr.road || ''} ${addr.subDistrict || ''} ${addr.district || ''} ${addr.province || ''} ${addr.postalCode || ""}`.trim();
            }

            function populateCardData(data) {
                if (!data || !data.updatedData) return;
                const fields = data.updatedData;

                if (data.photo?.startsWith("data:image")) {
                    const photoImg = document.getElementById("idCardPhoto");
                    if (photoImg) photoImg.src = data.photo;
                }

                const ignoreMask = ["sex", "prefixTH", "prefixEN"];

                Object.entries(fields).forEach(([key, value]) => {
                    const el = document.querySelector(`.info-value[data-field-name="${key}"]`);
                    if (el) {
                        const cleanValue = value || "";
                        let maskVal = maskText(cleanValue);

                        if (ignoreMask.includes(key)) maskVal = cleanValue;

                        el.setAttribute("data-full-value", cleanValue);
                        el.setAttribute("data-mask-value", maskVal);

                        el.textContent = maskVal;
                    }
                });
            }

            var capture = typeof getCapture === "function" ? getCapture() : null;
            if (capture) {
                const captureImg = document.getElementById("capturePhoto");
                if (captureImg) captureImg.src = capture;
            }

            if (cardData) {
                const fields = {
                    citizenID: cardData.citizenID,
                    dateOfBirth: formatDateTH(cardData.dateOfBirth),
                    prefixTH: cardData.thaiPersonalInfo?.prefix || "",
                    firstNameTH: cardData.thaiPersonalInfo?.firstName || "",
                    lastNameTH: cardData.thaiPersonalInfo?.lastName || "",
                    middleNameTH: cardData.thaiPersonalInfo?.middleName || "",
                    prefixEN: cardData.englishPersonalInfo?.prefix || "",
                    firstNameEN: cardData.englishPersonalInfo?.firstName || "",
                    middleNameEN: cardData.englishPersonalInfo?.middleName || "",
                    lastNameEN: cardData.englishPersonalInfo?.lastName || "",
                    sex: getsexText(cardData.sex),
                    address: getAddress(cardData.addressInfo),
                    issueDate: formatDateTH(cardData.issueDate),
                    expireDate: formatDateTH(cardData.expireDate),
                };
                cardData.updatedData = fields;
                populateCardData(cardData);
            }

            const ConfirmBtn = document.getElementById("confirm-btn");
            if (ConfirmBtn) ConfirmBtn.addEventListener("click", function() {
                if (typeof ConfirmData === "function") ConfirmData();
            });
        });
    </script>

    <audio id="click-sound" src="/audio/normal_click.wav" preload="auto"></audio>

    </div>
</body>
