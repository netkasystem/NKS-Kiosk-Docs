@{
    ViewData["Title"] = "Step12";
    ViewBag.HideHeader = true;
    ViewBag.HideFooter = true;
    ViewBag.HideButton = true;
    ViewBag.ShowLangToggle = true;
}
<body class="kiosk-body">
    <div class="bg-decoration z-0">
        <div class="bg-gradient-top-notice"></div>
        <div class="bg-gradient-bottom"></div>
    </div>
    <div class="kiosk-content z-10">

        <header class="kiosk-header">
            <div class="logo-container">
                <img id="photo" src="/images/icons/maersk.png" alt="Maersk Logo" class="maersk-img" />
            </div>

        </header>

        <div class="v-kiosk-display-wrapper">
            <div class="v-kiosk-main-card">

                <div class="v-kiosk-header-group">
                    <h2 data-i18n="id card information" class="v-kiosk-title">ข้อมูลบัตรประจำตัวประชาชน</h2>
                    <button class="icon-button" id="toggle-vision-btn">
                        <img src="/images/icons/vision.svg" alt="Toggle Vision" />
                    </button>
                </div>

                <div class="v-kiosk-profile-horizontal">
                    <div class="v-kiosk-avatar-wrapper">
                        <img id="idCardPhoto" src="/images/icons/Profile_id.svg" alt="ID Photo">
                    </div>
                    <div class="v-kiosk-name-stack">
                        <div class="v-kiosk-name-th">
                            <div class="info-value" data-field-name="prefixTH"></div>
                            <div class="info-value" data-field-name="firstNameTH"></div>
                            <div class="info-value" data-field-name="middleNameTH"></div>
                            <div class="info-value" data-field-name="lastNameTH"></div>
                        </div>
                        <div class="v-kiosk-name-en">
                            <div class="info-value" data-field-name="prefixEN"></div>
                            <div class="info-value" data-field-name="firstNameEN"></div>
                            <div class="info-value" data-field-name="middleNameEN"></div>
                            <div class="info-value" data-field-name="lastNameEN"></div>
                        </div>
                    </div>
                </div>

                <div class="v-kiosk-data-container">
                    <div class="v-kiosk-data-list">
                        <div class="v-kiosk-data-row">
                            <label class="v-kiosk-label" data-i18n="citizen id number">เลขบัตรประจำตัวประชาชน</label>
                            <div class="info-value" data-field-name="citizenID" data-full-value=""></div>
                        </div>
                        <div class="v-kiosk-data-row">
                            <label class="v-kiosk-label" data-i18n="date of birth">วันเกิด</label>
                            <div class="info-value" data-field-name="dateOfBirth" data-full-value=""></div>
                        </div>
                        <div class="v-kiosk-data-row">
                            <label class="v-kiosk-label" data-i18n="gender">เพศ</label>
                            <div class="info-value" data-field-name="sex" data-full-value=""></div>
                        </div>
                        <div class="v-kiosk-data-row v-kiosk-data-row--address">
                            <label class="v-kiosk-label" data-i18n="address">ที่อยู่</label>
                            <div class="info-value" data-field-name="address" data-full-value=""></div>
                        </div>
                        <div class="v-kiosk-data-row">
                            <label class="v-kiosk-label" data-i18n="issue date">วันออกบัตร</label>
                            <div class="info-value" data-field-name="issueDate" data-full-value=""></div>
                        </div>
                        <div class="v-kiosk-data-row">
                            <label class="v-kiosk-label" data-i18n="expiry date">วันหมดอายุบัตร</label>
                            <div class="info-value" data-field-name="expireDate" data-full-value=""></div>
                        </div>
                    </div>
                </div>

                <div class="v-kiosk-capture-area">
                    <span class="v-kiosk-capture-label" data-i18n="face scan photo">
                        ภาพถ่ายยืนยันตัวตนจากเครื่องสแกน
                    </span>
                    <div class="v-kiosk-capture-frame">
                        <div class="v-kiosk-capture-img-wrapper">
                            <img id="capturePhoto" src="/images/icons/Profile.jpg" alt="Capture Photo" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="kiosk-action-bar style-modern kiosk-action-bar--compact" id="confirm-btn">
            <a asp-controller="Step" asp-action="Step17" class="kiosk-btn btn-solid">
                ยืนยันข้อมูล
            </a>
            <a asp-controller="Step" asp-action="Step1" class="kiosk-btn btn-outline">
                ข้อมูลไม่ถูกต้องและยกเลิก
            </a>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let cardData = getCardData();
            const mainToggleButton = document.getElementById("toggle-vision-btn");
            const allInfoValues = document.querySelectorAll(".info-value");

            if (mainToggleButton) {
                let isAllDataVisible = false;

                mainToggleButton.addEventListener("click", function () {
                    isAllDataVisible = !isAllDataVisible;

                    allInfoValues.forEach((element) => {
                        const fullValue = element.getAttribute("data-full-value");
                        const maskedValue = element.getAttribute("data-mask-value");

                        if (isAllDataVisible) {
                            element.textContent = fullValue || element.textContent;
                        } else {
                            element.textContent = maskedValue || element.textContent;
                        }
                    });

                    updateAllIcons(isAllDataVisible);
                });
            }

            function updateAllIcons(isVisible) {
                const mainIcon = document.querySelector("#toggle-vision-btn img");
                if (mainIcon) {
                    mainIcon.src = isVisible ? "/images/icons/eye.svg" : "/images/icons/vision.svg";
                    mainIcon.alt = isVisible ? "ซ่อนข้อมูล" : "ดูข้อมูล";
                }
            }

            function formatDateTH(dateStr) {
                if (!dateStr) return "";
                const monthTH = ["", "ม.ค.", "ก.พ.", "มี.ค.", "เม.ย.", "พ.ค.", "มิ.ย.", "ก.ค.", "ส.ค.", "ก.ย.", "ต.ค.", "พ.ย.", "ธ.ค."];
                const d = new Date(dateStr);
                return `${d.getDate()} ${monthTH[d.getMonth() + 1]} ${d.getFullYear() + 543}`;
            }

            function hideLastN(text, count = 4) {
                if (!text) return "";
                const str = String(text);
                if (str.length <= count) return "x".repeat(str.length);
                return str.slice(0, -count) + "x".repeat(count);
            }

            const maskText = (text) => hideLastN(text, 4);

            function getsexText(code) {
                return code === "1" ? "ชาย" : code === "2" ? "หญิง" : "ไม่ระบุ";
            }

            function getAddress(addr) {
                if (!addr) return "";
                return `${addr.houseNo || ''} ${addr.road || ''} ${addr.subDistrict || ''} ${addr.district || ''} ${addr.province || ''} ${addr.postalCode || ""}`.trim();
            }

            function populateCardData(data) {
                if (!data || !data.updatedData) return;
                const fields = data.updatedData;

                if (data.photo?.startsWith("data:image")) {
                    const photoImg = document.getElementById("idCardPhoto");
                    if (photoImg) photoImg.src = data.photo;
                }

                const ignoreMask = ["sex", "prefixTH", "prefixEN"];

                Object.entries(fields).forEach(([key, value]) => {
                    const el = document.querySelector(`.info-value[data-field-name="${key}"]`);
                    if (el) {
                        const cleanValue = value || "";
                        let maskVal = ignoreMask.includes(key) ? cleanValue : maskText(cleanValue);

                        el.setAttribute("data-full-value", cleanValue);
                        el.setAttribute("data-mask-value", maskVal);
                        el.textContent = maskVal;
                    }
                });
            }

            var capture = typeof getCapture === "function" ? getCapture() : null;
            if (capture) {
                const captureImg = document.getElementById("capturePhoto");
                if (captureImg) captureImg.src = capture;
            }

            if (cardData) {
                const fields = {
                    citizenID: cardData.citizenID,
                    dateOfBirth: formatDateTH(cardData.dateOfBirth),
                    prefixTH: cardData.thaiPersonalInfo?.prefix || "",
                    firstNameTH: cardData.thaiPersonalInfo?.firstName || "",
                    lastNameTH: cardData.thaiPersonalInfo?.lastName || "",
                    middleNameTH: cardData.thaiPersonalInfo?.middleName || "",
                    prefixEN: cardData.englishPersonalInfo?.prefix || "",
                    firstNameEN: cardData.englishPersonalInfo?.firstName || "",
                    middleNameEN: cardData.englishPersonalInfo?.middleName || "",
                    lastNameEN: cardData.englishPersonalInfo?.lastName || "",
                    sex: getsexText(cardData.sex),
                    address: getAddress(cardData.addressInfo),
                    issueDate: formatDateTH(cardData.issueDate),
                    expireDate: formatDateTH(cardData.expireDate),
                };
                cardData.updatedData = fields;
                populateCardData(cardData);
            }
        });
    </script>
</body>
