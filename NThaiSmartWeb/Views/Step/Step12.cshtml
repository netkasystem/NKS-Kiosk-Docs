            <div class="modal-header">
                <h2>แก้ไขข้อมูล</h2>
                <span class="close-button">&times;</span>
            </div>

            <form id="edit-form">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="input-id-number">เลขบัตรประชาชน</label>
                        <div class="input-wrapper">
                            <span class="old-data-placeholder"></span> <input type="text" id="input-id-number" data-source-field="id_number">
                        </div>
                    </div>
                    <div class="form-field">
                        <label for="input-birthdate">วันเกิด</label>
                        <input type="text" id="input-birthdate" data-source-field="birthdate">
                    </div>

                    <div class="form-field">
                        <label for="input-first-name">ชื่อ</label>
                        <input type="text" id="input-first-name" data-source-field="first_name">
                    </div>

                    <div class="form-field">
                        <label for="input-last-name">นามสกุล</label>
                        <input type="text" id="input-last-name" data-source-field="last_name">
                    </div>

                    <div class="form-field">
                        <label for="input-gender">เพศ</label>
                        <input type="text" id="input-gender" data-source-field="gender">
                    </div>

                    <div class="form-field">
                        <label for="input-religion">ศาสนา</label>
                        <input type="text" id="input-religion" data-source-field="religion">
                    </div>

