@{
    ViewData["Title"] = "สถานะการอ่านบัตรประชาชน";
}

<div class="container-fluid mt-4">
    <div class="row">
        <!-- ซ้าย: รายการตู้ Kiosk -->
        <div class="col-lg-3 col-12 border-end" style="max-height: 80vh; overflow-y: auto;">
            <!-- กล้องและรูปบัตรสำหรับเปรียบเทียบ -->
            <div id="recog-card">
                <video id="videoInput" autoplay muted playsinline style="display: none;"></video>

                <div class="mt-3 text-center">
                    <button class="btn btn-success" id="captureFace" style="display: none;">📸 Capture ใบหน้า</button>
                </div>

                <div class="mt-3 text-center">
                    <canvas id="faceCanvas" style="display: none;"></canvas>
                </div>

                <div id="identity-status" class="mt-3 fw-bold text-center text-info"></div>
            </div>
        </div>

        <!-- ขวา: ข้อมูลบัตรและกล้อง -->
        <div class="col-lg-9 col-12">
            <h3>สถานะการอ่านบัตรประชาชน</h3>
            <p id="kiosk-no" class="fw-bold text-primary"></p>
            <div id="kiosk-status" class="status-box d-flex align-items-center gap-2">
                <span id="kiosk-status-icon" class="status-icon">✅</span>
                <span id="kiosk-status-text">กรุณาเลือกตู้ Kios</span>
                <span id="kiosk-status-time" class="text-muted small ms-2"></span>
            </div>

            <!-- ข้อมูลบัตร -->
            <div id="citizen-card">
                <div>
                    <img id="photo" src="/images/icons/id-card-icon.png" alt="บัตรประชาชน" class="img-thumbnail" style="width: 180px;" />
                </div>
                <div>
                    <h4>🆔 รหัสประชาชน: <span id="citizenID"></span></h4>
                    <p>👤 ชื่อ (TH): <span id="fullNameTH"></span></p>
                    <p>👤 ชื่อ (EN): <span id="fullNameEN"></span></p>
                    <p>🎂 วันเกิด: <span id="dob"></span></p>
                    <p>🧾 ที่อยู่: <span id="address"></span></p>
                    <p>📅 ออกเมื่อ: <span id="issueDate"></span></p>
                    <p>📅 หมดอายุ: <span id="expireDate"></span></p>
                    <p>🏢 ออกโดย: <span id="issuer"></span></p>
                </div>

            </div>
        </div>
    </div>
</div>