@{
    ViewData["Title"] = "สถานะการอ่านบัตรประชาชน";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            @Html.Partial("~/Views/Step/Step10.cshtml")
        </div>

        <div class="col-lg-9 col-12">
            <h3 data-i18n="id card reading status">สถานะการอ่านบัตรประชาชน</h3>
            <p id="kiosk-no" class="fw-bold text-primary"></p>
            <div id="kiosk-status" class="status-box d-flex align-items-center gap-2">
                <span id="kiosk-status-icon" class="status-icon">✅</span>
                <span id="kiosk-status-text" data-i18n="please select a kiosk">กรุณาเลือกตู้ Kios</span>
                <span id="kiosk-status-time" class="text-muted small ms-2"></span>
            </div>

            <!-- ข้อมูลบัตร -->
            <div id="citizen-card">
                <div>
                    <img id="photo" src="/images/icons/id-card-icon.png" alt="บัตรประชาชน" class="img-thumbnail" style="width: 180px;" />
                </div>
                <div>
                    <h4 data-i18n="citizen id">🆔 รหัสประชาชน: <span id="citizenID"></span></h4>
                    <p data-i18n="name th">👤 ชื่อ (TH): <span id="fullNameTH"></span></p>
                    <p data-i18n="name en">👤 ชื่อ (EN): <span id="fullNameEN"></span></p>
                    <p data-i18n="date of birth">🎂 วันเกิด: <span id="dob"></span></p>
                    <p data-i18n="address">🧾 ที่อยู่: <span id="address"></span></p>
                    <p data-i18n="issue date">📅 ออกเมื่อ: <span id="issueDate"></span></p>
                    <p data-i18n="expiry date">📅 หมดอายุ: <span id="expireDate"></span></p>
                    <p data-i18n="issued by">🏢 ออกโดย: <span id="issuer"></span></p>
                </div>

            </div>
        </div>

        <div class="col-lg-3 col-12">
            <img id="previewImg" style="max-width: 100%; margin-top: 10px;" />
        </div>

        <div class="col-lg-9 col-12">
            <button id="submitBtn" style="display: none;">Submit</button>
        </div>
    </div>
</div>