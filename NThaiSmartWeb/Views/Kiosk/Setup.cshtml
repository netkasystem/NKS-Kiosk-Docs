@{
    ViewData["Title"] = "Configure Kiosk";
}
<div class="container mt-4">
@*     <h2>Kiosk Setup</h2>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" onclick="downloadFileSetup('setup-kiosk-install')">Generate Kiosk Script</button>
        <button type="button" class="btn btn-secondary" onclick="downloadFileSetup('setup-kiosk-config')">Generate Docker Script</button>
    </div> *@
</div>

<div class="header" style="margin-top:0%;">
    <div class="normal-container">
        <h2>
            ขั้นตอน
        </h2>
    </div>
    <div class="normal-container">
        <h1>
            การติดตั้ง
        </h1>
    </div>
    <div class="glass-step-vertical">
        <div class="glass-step-box">
            <div class="step-number">1</div>
            <div class="step-label">ดาวน์โหลดไฟล์ </div>
            <button type="submit" class="script-button" onclick="downloadFileSetup('setup-kiosk-install')">  <img src="/images/icons/download.svg" class="download_icon" /> Kiosk Script</button>

        </div>
        <div class="glass-step-box">
            <div class="step-number">2</div>
            <div class="step-label">ดาวน์โหลดไฟล์</div>
            <button type="button" class="script-button" onclick="openZoneModal()"> <img src="/images/icons/download.svg" class="download_icon" /> Docker Script</button>
        </div>
      @*   <div class="glass-step-box">
            <div class="step-number">2</div>
            <div class="step-label">ดาวน์โหลดไฟล์</div>
            <button type="button" class="script-button" onclick="downloadFileSetup('setup-kiosk-config')"> <img src="/images/icons/download.svg" class="download_icon" /> Docker Script</button>
        </div> *@
        <div class="glass-step-box">
            <div class="step-number">3</div>
            <div class="step-label">ปฏิบัติตามไฟล์</div>
            <button type="button" class="script-button" onclick="downloadFileSetup('setup-kiosk-manual')">
                <img src="/images/icons/download.svg"  class="download_icon">คู่มือการติดตั้ง
            </button>
        </div>
        <div class="glass-step-box">
            <div class="step-number">4</div>
            <div class="step-label">รีสตาร์ทเครื่อง</div>
        </div>
    </div>

    <div id="zoneModal" class="zone-modal" aria-hidden="true">
        <div class="zone-modal-backdrop" onclick="closeZoneModal()"></div>
        <div class="zone-modal-content" role="dialog" aria-labelledby="zoneModalTitle" onclick="event.stopPropagation()">
            <button class="close-btn" aria-label="ปิด" onclick="closeZoneModal()">&times;</button>
            <button class="close-btn" aria-label="ปิด" onclick="closeZoneModal()">&times;</button>
            <div class="modal-text-header">
                <h2 id="zoneModalTitle" class="modal-text-header">
                   กรุณาดาวน์โหลด
                </h2>
            </div>
            <div class="modal-text-h1">
                <h1 class="modal-text-h1">
                   ตาม Zone พื้นที่ที่ต้องการติดตั้ง
                </h1>
            </div>
            <div class="zone-buttons">
                <div class="zone-card" data-zone="1">
                    <div class="zone-title">Zone 1</div>
                    <div class="zone-desc">สำหรับพื้นที่ <span class="highlight-yellow">กรุงเทพฯ และปริมณฑล</span></div>
                    <button class="script-button small" onclick="downloadFileSetup('setup-kiosk-config')" >ดาวน์โหลด</button>
                </div>
                <div class="zone-card" data-zone="2">
                    <div class="zone-title">Zone 2</div>
                    <div class="zone-desc">สำหรับ <span class="highlight-yellow">ภาคตะวันออกและภาคกลาง</span></div>
                    <button class="script-button small" onclick="downloadFileSetup('setup-kiosk-config')">ดาวน์โหลด</button>
                </div>
                <div class="zone-card" data-zone="3">
                    <div class="zone-title">Zone 3</div>
                    <div class="zone-desc">สำหรับ <span class="highlight-yellow">ภาคเหนือ</span> (เช่น เชียงใหม่, ลำพูน)</div>
                    <button class="script-button small" onclick="downloadFileSetup('setup-kiosk-config')">ดาวน์โหลด</button>
                </div>
                <div class="zone-card" data-zone="4">
                    <div class="zone-title">Zone 4</div>
                    <div class="zone-desc">สำหรับ <span class="highlight-yellow">ภาคใต้</span> (เช่น ภูเก็ต, สงขลา)</div>
                    <button class="script-button small" onclick="downloadFileSetup('setup-kiosk-config')">ดาวน์โหลด</button>
                </div>
                <div class="zone-card" data-zone="5">
                    <div class="zone-title">Zone 5</div>
                    <div class="zone-desc"> สำหรับ<span class="highlight-yellow"> ภาคตะวันออกเฉียงเหนือ </span> (เช่น ขอนแก่น, อุดรธานี)</div>
                    <button class="script-button small" onclick="downloadFileSetup('setup-kiosk-config')">ดาวน์โหลด</button>
                </div>
            </div>
        </div>
</div>
<script src="~/js/kiosk_setup.js"></script>
