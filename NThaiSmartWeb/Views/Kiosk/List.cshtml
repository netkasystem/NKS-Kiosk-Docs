@{
    ViewData["Title"] = "สถานะตู้ Kiosk";
}

<style>
    #kiosk-list .list-group-item {
        font-size: 0.95rem;
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 6px;
    }

        #kiosk-list .list-group-item.active {
            background-color: #0d6efd;
            color: white;
        }
</style>

<div class="container-fluid mt-4">
    <div class="row">
        <!-- ซ้าย: รายการตู้ Kiosk -->
        <div class="col-lg-4 col-md-6 col-12 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">🖥️ รายการตู้ Kiosk</h5>
                </div>
                <div class="card-body p-2" style="max-height: 70vh; overflow-y: auto;">
                    <div id="kiosk-list" class="list-group">
                        <!-- ตัวอย่างรายการ -->
                        <!--
                        <a href="#" class="list-group-item list-group-item-action">
                            🖥️ Kiosk-001 <span class="badge bg-success float-end">Online</span>
                        </a>
                        -->
                    </div>
                </div>
            </div>
        </div>

        <!-- ขวา: Placeholder สำหรับอนาคต (Optional) -->
        <div class="col-lg-8 d-none d-lg-block text-muted">
            <div class="h-100 d-flex align-items-center justify-content-center">
                <p class="text-center">เลือก Kiosk จากรายการด้านซ้ายเพื่อดูรายละเอียดเพิ่มเติม</p>
            </div>
        </div>
    </div>
</div>