@inject Microsoft.AspNetCore.Mvc.Rendering.IHtmlHelper Html
@inject IWebHostEnvironment env
@functions {
    public string IsActive(string controller, string action = "")
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        if (controller == currentController && (string.IsNullOrEmpty(action) || action == currentAction))
        {
            return "active";
        }

        return "";
    }
}

<!DOCTYPE html>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - N-ThaiSmart</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/select2/css/select2.css" />
    <link rel="stylesheet" href="~/lib/fortawesome/fontawesome-free/css/all.min.css">

    <link rel="icon" type="image/png" href="~/favicon.png" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/master.css" asp-append-version="true" />

</head>
<body>

    @* @if (!(ViewBag.HideHeader is true)) *@
    @if (!(ViewBag.HideHeader is true) || env.IsDevelopment())
    {
        <header>
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
                <div class="container">
                    <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">Netka-ThaiSmart</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <span class="nav-link connected-kiosk"></span>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="stepsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    🚶 Steps
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="stepsDropdown">
                                    <li><a class="dropdown-item @IsActive("Step", "Step1")" asp-controller="Step" asp-action="Step1">Step 1</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step2")" asp-controller="Step" asp-action="Step2">Step 2</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step3")" asp-controller="Step" asp-action="Step3">Step 3</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step4")" asp-controller="Step" asp-action="Step4">Step 4</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step5")" asp-controller="Step" asp-action="Step5">Step 5</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step6")" asp-controller="Step" asp-action="Step6">Step 6</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step7")" asp-controller="Step" asp-action="Step7">Step 7</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step8")" asp-controller="Step" asp-action="Step8">Step 8</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step9")" asp-controller="Step" asp-action="Step9">Step 9</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step10")" asp-controller="Step" asp-action="Step10">Step 10</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step11")" asp-controller="Step" asp-action="Step11">Step 11</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step12")" asp-controller="Step" asp-action="Step12">Step 12</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step14")" asp-controller="Step" asp-action="Step14">Step 14</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "Step17")" asp-controller="Step" asp-action="Step17">Step 17</a></li>
                                    <li><a class="dropdown-item @IsActive("Step", "StepEnd")" asp-controller="Step" asp-action="StepEnd">StepEnd</a></li>
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @IsActive("Kiosk", "List")" asp-controller="Kiosk" asp-action="List">🖥️ Kiosk List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Kiosk", "Setup")" asp-controller="Kiosk" asp-action="Setup">🛠️ Setup Kiosk</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Kiosk", "CardReader")" asp-controller="Kiosk" asp-action="CardReader">🪪 Card Reader & Identify</a>
                            </li>

                            <li class="nav-item">
                                <a href="#" id="logout" class="nav-link">👋 Logout</a>
                            </li>

                            <!-- เพิ่มเมนูอื่น ๆ ตามต้องการ -->
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    <!-- Countdown Modal -->
    <div class="modal fade" id="cardRemovedModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered text-center mw-100 align-content-center">

            <div class="modal-confirmation">
                <p style="font-size:4rem; font-weight:900;">มีการดึงบัตรออก</p>
                <img src="/images/icons/font_card_id.svg" class="congratulations-image" style="margin-bottom:40px; margin-top:40px;" />

                <div class="modal-footer">
                    <p>กำลังกลับสู่หน้าจอหลักใน <span id="countdown">5</span> วินาที</p>

                </div>
            </div>
        </div>
    </div>

    <div class="container mt-4">
        <main ng-app="main" role="main" class="pb-5">
            <div class="timer" style="background-color: slategray;display: block !important;width: fit-content;padding-right: 10px;">
                @if (env.IsDevelopment())
                {
                    <tspan>Dev Mode</tspan>
                    <span> ⏳ Time elapsed: <span id="timer">0</span> seconds</span>
                }
            </div>

            <div class="row-logout p-3 text-center" style="height: 7vh; width: 10vw; z-index: 99; position: fixed;top: 2vh;right: 2vw;">
                <i class="fas fa-sign-out-alt fa-2x" title="Logout" id="icon-logout" style="color:white; display:none"></i>
            </div>

            @RenderBody()

        </main>
    </div>

    @if (!(ViewBag.HideButton is true))
    {
        <footer>
            <button class="footer-button" id="back-button">
                <img src="/images/icons/back_icon.svg" class="footer_icon">
            </button>
        </footer>
    }

    @if (!(ViewBag.HideFooter is true))
    {
        @await Html.PartialAsync("_Footer")
    }

    <script>
           document.addEventListener('DOMContentLoaded', function () {
            const backButton = document.getElementById('back-button');
            const refreshButton = document.getElementById('refresh-button');
            const settingButton = document.getElementById('setting-button');

            if (backButton) {
                backButton.addEventListener('click', function () {
                    window.location.href = '/Step/Step1'; // ไปหน้า Step1
                });
            }

            if (refreshButton) {
                refreshButton.addEventListener('click', function () {
                    location.reload(); // รีเฟรชหน้านี้
                });
            }

            if (settingButton) {
                settingButton.addEventListener('click', function () {
                    window.location.href = '/Kiosk/Setup';
                });
            }

            let lastClickTime;
            let clicks = 0;
            $('#icon-logout').on('click', function () { window.location.href = '/logout'; });

            document.querySelector('.row-logout').addEventListener('click', function () {
                const now = new Date().getTime();
                lastClickTime = lastClickTime ?? now;

                if (now - lastClickTime < 1000)
                    clicks++;
                else
                    clicks = 1;

                lastClickTime = now;

                if (clicks === 3) {
                    document.getElementById('icon-logout').style.display = 'block';
                    setTimeout(() => {
                        document.getElementById('icon-logout').style.display = 'none';
                    }, 1000 * 10);
                    clicks = 0;
                }
            });

            document.addEventListener('wheel', function(e) {
            if (e.ctrlKey) {
                e.preventDefault();
            }
        }, { passive: false });
        });
    </script>

    <!-- jQuery ก่อน -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- Bootstrap ต้องตามหลัง jQuery -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- AngularJS -->
    <script src="~/lib/angular.js/angular.min.js"></script>

    <!-- Select2 ต้องมาก่อนใช้งาน directive/JS custom -->
    <script src="~/lib/select2/js/select2.js"></script>

    <!-- SignalR -->
    <script src="~/lib/microsoft-signalr/signalr.min.js"></script>

    <!-- crypto-js -->
    <script src="~/lib/crypto-js/crypto-js.min.js"></script>

    <!-- face-api -->
    <script src="~/lib/face-api/face-api.min.js"></script>

    <script src="~/js/angularjs-directive.js" asp-append-version="true"></script>
    <script src="~/js/common-ajax.js" asp-append-version="true"></script>
    <script src="~/js/common-script.js" asp-append-version="true"></script>
    <script src="~/js/signalr-config.js" asp-append-version="true"></script>
    <script src="~/js/login.js" asp-append-version="true"></script>
    <script src="~/js/face-recognition.js" asp-append-version="true"></script>
    <script src="~/js/step-controller.js" asp-append-version="true"></script>
    <script src="~/js/kiosk_setup.js"></script>

</body>
</html>
