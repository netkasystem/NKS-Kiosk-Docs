{
  "version": "3.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "select2@4.0.13",
      "destination": "wwwroot/lib/select2/"
    },
    {
      "library": "microsoft-signalr@8.0.7",
      "destination": "wwwroot/lib/microsoft-signalr/"
    },
    {
      "library": "crypto-js@4.2.0",
      "destination": "wwwroot/lib/crypto-js/",
      "files": [
        "crypto-js.min.js",
        "crypto-js.js"
      ]
    },
    {
      "library": "jquery@3.7.1",
      "destination": "wwwroot/lib/jquery/"
    },
    {
      "library": "bootstrap@5.3.7",
      "destination": "wwwroot/lib/bootstrap/"
    },
    {
      "library": "angular.js@1.8.3",
      "destination": "wwwroot/lib/angular.js/"
    },
    {
      "provider": "jsdelivr",
      "library": "@fortawesome/fontawesome-free@6.1.1",
      "destination": "wwwroot/lib/fortawesome/fontawesome-free/"
    },
    {
      "library": "flag-icon-css@3.5.0",
      "destination": "wwwroot/lib/flag-icon-css/"
    }
  ]
}