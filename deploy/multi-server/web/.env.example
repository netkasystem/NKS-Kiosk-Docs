# === จำเป็น — ต้องแก้ก่อน deploy ===

# TODO: แก้ IP ของ Database Server
NSDX_CONNECTION_ENV=Server=DB_IP;Port=3306;Database=n_smart_kiosk;User=nkssdsk;Password=xxx;TreatTinyAsBoolean=true;Convert Zero Datetime=True;Connection Timeout=600;default command timeout=600;CharSet=utf8mb4

# TODO: แก้ IP ของเครื่อง Storage + port ที่ใช้จริง
# - ถ้าใช้ Netka.Kiosk.Redis แยก → port 6380
# - ถ้าใช้ NSDX.Supreme.Redis ร่วม → port 6379
REDIS_CONNECTION=STORAGE_IP:6380

# TODO: แก้ IP ของเครื่อง Storage + port ที่ใช้จริง
# - ถ้าใช้ Netka.Kiosk.FileServer แยก → port 8082
# - ถ้าใช้ NSDX.Supreme.FileServer ร่วม → port 8080
FILE_STORAGE_URL=http://STORAGE_IP:8082

# TODO: แก้ tag ของ image ที่ต้องการ deploy
IMAGE_TAG=latest

# === มี default — ใส่เมื่อต้องการเปลี่ยน ===
COOKIE_NAME=NetkaKiosk
SESSION_TIMEOUT=8
