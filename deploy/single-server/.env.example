# =============================================================
# .env — Single Server (ใช้ร่วมกันทั้ง redis + web compose)
# คัดลอกเป็น .env แล้วแก้ค่าก่อน deploy
# =============================================================

# === จำเป็น — ต้องแก้ก่อน deploy ===

# TODO: แก้ IP / ชื่อ Database Server
NSDX_CONNECTION_ENV=Server=DB_IP;Port=3306;Database=n_smart_kiosk;User=nkssdsk;Password=xxx;TreatTinyAsBoolean=true;Convert Zero Datetime=True;Connection Timeout=600;default command timeout=600;CharSet=utf8mb4

# TODO: แก้ tag ของ image ที่ต้องการ deploy
IMAGE_TAG=latest

# === มี default — ใส่เมื่อต้องการเปลี่ยน ===

# ชื่อ cookie session
COOKIE_NAME=NetkaKiosk

# ชื่อ container ของ Redis (ต้องตรงกับ REDIS_CONNECTION)
REDIS_CONTAINER_NAME=Netka.Kiosk.Redis

# Redis connection — ชี้ไปที่ container name ของ redis ที่รันบนเครื่องเดียวกัน
REDIS_CONNECTION=Netka.Kiosk.Redis:6379

# Session timeout (ชั่วโมง)
SESSION_TIMEOUT=8
